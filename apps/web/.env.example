NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
CRON_SECRET=
# Twilio — for /contribute SMS verification + notify-contributors cron.
# All optional; SMS sender falls back to console.log when unset.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Free, instant — https://511.org/open-data/token. Required for /api/cron/sync-live-incidents
# to fetch the 511 traffic + transit sources. DataSF sources work without keys.
SF_511_API_KEY=
# Optional Socrata app token — raises DataSF rate limit from 1k/hr to 10k/hr per IP.
SOCRATA_APP_TOKEN=

# Upstash Redis — used as L2 cache for HLS manifests + segments in /api/hls.
# Auto-provided as KV_REST_API_URL / KV_REST_API_TOKEN if you add the Vercel
# Marketplace Upstash integration. Optional: route falls back to L1 (in-memory).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Resend — used by /api/cron/send-alerts to email neighborhood subscribers.
# Optional: route falls back to console.log when unset.
RESEND_API_KEY=
ALERTS_FROM="WatchDog <alerts@watchdog.sf>"

# Public site URL — used in alert emails for the unsubscribe link.
NEXT_PUBLIC_SITE_URL=https://watchdog-yc.vercel.app

# --- Environmental & sensor layer (Batch B) -----------------------------
# Each source degrades gracefully when its key is missing — the cron route
# /api/cron/sync-env returns `disabled: true` per missing-key source.

# PurpleAir AQI — request a free key at https://api.purpleair.com/.
PURPLEAIR_API_KEY=

# OpenSky Network ADS-B — keyless works but is heavily rate-limited.
# Provide HTTP Basic credentials to lift the per-IP cap. Both must be set
# together. Register at https://opensky-network.org/.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# AISStream.io — free websocket marine traffic. Register at
# https://aisstream.io/. Without this, the marine layer is empty.
AISSTREAM_API_KEY=

# BART BSA — falls back to the documented public sample key for low
# traffic. Get your own at https://api.bart.gov/api/register.aspx.
BART_API_KEY=
