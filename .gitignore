# Dispatch audio lives in Supabase Storage (bucket: dispatch-audio).
# README.md + manifest.example.json stay tracked; binaries do not.
apps/web/public/dispatch-audio/*.m4a
apps/web/public/dispatch-audio/*.mp3
apps/web/public/dispatch-audio/*.wav
apps/web/public/dispatch-audio/manifest.json
